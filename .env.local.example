# Anthropic Claude API — for pitch evaluation
# Get one at https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# OpenAI API — used for Whisper transcription
# Get one at https://platform.openai.com/api-keys
OPENAI_API_KEY=

# --- Optional: admin notifications ---
# If set, every successful evaluation emails a full report to ADMIN_EMAIL.
# Leave both blank to disable.
# Sign up at https://resend.com (free tier covers 100 emails/day).
# The admin email must be verified in your Resend account.
RESEND_API_KEY=
ADMIN_EMAIL=
